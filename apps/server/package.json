{
  "name": "@devcollab/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "db:push": "prisma db push --schema=src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "db:seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@devcollab/types": "workspace:*",
    "@google/generative-ai": "^0.15.0",
    "@prisma/client": "^5.15.0",
    "@upstash/redis": "^1.32.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.3.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "resend": "^3.3.0",
    "slugify": "^1.6.9",
    "socket.io": "^4.7.5",
    "streamifier": "^0.1.1",
    "stripe": "^15.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "prisma": "^5.15.0",
    "rimraf": "^5.0.7",
    "tsx": "^4.15.7",
    "typescript": "^5.4.0"
  }
}
