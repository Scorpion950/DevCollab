# ====================
# Database
# ====================
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres"

# ====================
# Auth
# ====================
JWT_SECRET="your-super-long-random-jwt-secret-at-least-32-chars"
JWT_REFRESH_SECRET="another-super-long-random-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ====================
# Redis (Upstash)
# ====================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ====================
# Cloudinary (File Uploads)
# ====================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ====================
# Email (Resend)
# ====================
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@devcollab.local"

# ====================
# AI (Google Gemini)
# ====================
GEMINI_API_KEY="AIzaSy_your_gemini_key"
AI_FREE_DAILY_LIMIT=10

# ====================
# Stripe (Payments)
# ====================
STRIPE_SECRET_KEY="sk_test_your_stripe_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRO_PRICE_ID="price_your_price_id"

# ====================
# App
# ====================
NODE_ENV="development"
SERVER_PORT=4000
SERVER_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SERVER_URL="http://localhost:4000"
